# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.venv/
venv/

# Data (generated, not committed)
data/scenarios/*.json
data/results/*.parquet
data/results/*.csv
# Per-evaluation artifacts hold FULL transcripts — including private-holdout
# scenario content when COT_BENCH_HOLDOUT_DIR is set. Never committable.
data/results/artifacts/

# Published leaderboard surfaces — these ARE committed by the weekly-eval
# publish step (.github/workflows/weekly-eval.yml). They must be un-ignored
# even though the broader data/results/*.csv rule above would otherwise swallow
# latest.csv. governance.md §4 and methodology.md name leaderboard.json +
# latest.csv as the published surfaces; history.jsonl is the append-only audit
# trail governance §1 leans on. Any change here must keep
# tests/test_published_surfaces_committable.py green (it runs `git check-ignore`
# against exactly the paths the publish step adds).
!data/results/leaderboard.json
!data/results/latest.csv
!data/results/history.jsonl
# published_surfaces.jsonl is the anti-memorization ledger: an append-only record
# of every published instantiated surface (instantiated_corpus_sha256). The
# publish step commits it alongside the leaderboard so the next published run can
# be blocked from re-exposing a surface that already shipped (closes the
# same-surface-reuse gap left open by #82). It must be committed each run or the
# anti-memorization history is discarded with the CI workspace.
!data/results/published_surfaces.jsonl

# Keep domain definitions
!data/domains/**/*.json

# Environment
.env
.env.local

# IDE
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# Traces
traces/
