# COT Bench — API Keys
#
# Copy this to .env and fill in your keys:
#   cp .env.example .env
#
# Then load them:
#   source .env          (bash)
#   export $(cat .env | grep -v '^#' | xargs)  (alternative)

# Required — user/tool simulators (GPT-4.1-mini) and OpenAI models under test
export OPENAI_API_KEY=sk-...

# Required — Opus judge and Anthropic models under test
export ANTHROPIC_API_KEY=sk-ant-...

# Required — open judges (Kimi K2.6, GLM-4.6) and the open-weight models under
# test (DeepSeek-V4 Pro, Qwen3.7-Max, MiniMax M3, Mistral Large 3), all via one
# OpenRouter key. Replaces the old per-provider deepseek/qwen/together/mistral keys.
export OPENROUTER_API_KEY=sk-or-...

# Optional — only needed for the Gemini models under test
export GOOGLE_API_KEY=
