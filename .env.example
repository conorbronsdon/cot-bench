# COT Bench — API Keys
#
# Copy this to .env and fill in your keys:
#   cp .env.example .env
#
# Then load them:
#   source .env          (bash)
#   export $(cat .env | grep -v '^#' | xargs)  (alternative)

# Required — used by user/tool simulators (GPT-4.1-mini) and OpenAI models under test
export OPENAI_API_KEY=sk-...

# Required — used by Opus judge and Anthropic models under test
export ANTHROPIC_API_KEY=sk-ant-...

# Optional — only needed if evaluating these specific models
export GOOGLE_API_KEY=
export DEEPSEEK_API_KEY=
export TOGETHER_API_KEY=
export MISTRAL_API_KEY=
export QWEN_API_KEY=
