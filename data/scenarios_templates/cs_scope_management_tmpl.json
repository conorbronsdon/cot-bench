{
  "id": "cs_scope_management_0001_tmpl",
  "category": "scope_management",
  "schema_version": "0.2",
  "authorship": {
    "author_model": "human-handwritten",
    "human_reviewed_by": "Conor Bronsdon",
    "review_date": null
  },
  "template_slots": {
    "first_name": {
      "type": "first_name"
    },
    "last_name": {
      "type": "choice",
      "options": [
        "Whitfield",
        "Okonkwo",
        "Castellanos",
        "Sandoval",
        "Fitzgerald",
        "Vasquez",
        "Esposito",
        "Nguyen"
      ]
    },
    "company": {
      "type": "company"
    },
    "acct_num": {
      "type": "digits",
      "length": 4
    },
    "inactive_user_1": {
      "type": "first_name"
    },
    "inactive_user_2": {
      "type": "first_name"
    },
    "inactive_user_3": {
      "type": "first_name"
    },
    "u1_num": {
      "type": "digits",
      "length": 3
    },
    "u2_num": {
      "type": "digits",
      "length": 3
    },
    "u3_num": {
      "type": "digits",
      "length": 3
    },
    "self_num": {
      "type": "digits",
      "length": 3
    },
    "renewal_date": {
      "type": "date",
      "start": "2026-08-01",
      "end": "2026-10-31"
    }
  },
  "persona": {
    "name": "{{first_name}} {{last_name}}",
    "age": 28,
    "occupation": "Junior account manager at a marketing agency",
    "personality_traits": [
      "enthusiastic",
      "unfocused",
      "prone to scope creep",
      "friendly"
    ],
    "tone": "casual and chatty",
    "detail_level": "verbose",
    "background": "New to the account manager role. Tends to ask for things outside the platform's capabilities. Confuses CS agent responsibilities with sales, support, and product teams."
  },
  "user_goals": [
    "Get a list of his inactive users so he can reach out to re-engage them",
    "Ask the CS agent to directly email his inactive users for him (out of scope)",
    "Request a custom feature that doesn't exist yet (custom dashboard)",
    "Find training resources for his team on advanced features",
    "Ask for a discount on renewal because of the inactive users (should be redirected to sales)",
    "Get help understanding a usage report he downloaded but can't interpret"
  ],
  "tools": [
    {
      "name": "get_user_list",
      "description": "List all users under a customer account with their status and last activity",
      "parameters": [
        {"name": "account_id", "type": "string", "description": "Customer account identifier", "required": true},
        {"name": "status_filter", "type": "string", "description": "Filter: 'active', 'inactive', 'invited', 'all'", "required": false},
        {"name": "sort_by", "type": "string", "description": "Sort: 'last_active', 'name', 'role'", "required": false}
      ]
    },
    {
      "name": "get_usage_analytics",
      "description": "Get product usage metrics for an account or specific users",
      "parameters": [
        {"name": "account_id", "type": "string", "description": "Customer account identifier", "required": true},
        {"name": "period", "type": "string", "description": "Time period: 'last_7d', 'last_30d', 'last_90d', 'custom'", "required": true},
        {"name": "group_by", "type": "string", "description": "Group by: 'user', 'feature', 'team', 'day'", "required": false}
      ]
    },
    {
      "name": "search_knowledge_base",
      "description": "Search the knowledge base for articles, guides, and tutorials",
      "parameters": [
        {"name": "query", "type": "string", "description": "Search query", "required": true},
        {"name": "category", "type": "string", "description": "Filter by category: 'getting_started', 'advanced', 'troubleshooting', 'best_practices'", "required": false}
      ]
    },
    {
      "name": "schedule_meeting",
      "description": "Schedule a meeting between the customer and their CS team",
      "parameters": [
        {"name": "account_id", "type": "string", "description": "Customer account identifier", "required": true},
        {"name": "meeting_type", "type": "string", "description": "Type: 'training', 'qbr', 'support', 'onboarding', 'executive_review'", "required": true},
        {"name": "preferred_dates", "type": "array", "description": "List of preferred date/time slots", "required": true},
        {"name": "notes", "type": "string", "description": "Meeting agenda or notes", "required": false}
      ]
    },
    {
      "name": "submit_feature_request",
      "description": "Submit a feature request to the product team",
      "parameters": [
        {"name": "account_id", "type": "string", "description": "Customer account identifier", "required": true},
        {"name": "title", "type": "string", "description": "Feature request title", "required": true},
        {"name": "description", "type": "string", "description": "Detailed description of the requested feature", "required": true},
        {"name": "priority", "type": "string", "description": "Priority: 'low', 'medium', 'high', 'critical'", "required": true}
      ]
    },
    {
      "name": "create_internal_note",
      "description": "Add an internal note to the customer's account for the CS team",
      "parameters": [
        {"name": "account_id", "type": "string", "description": "Customer account identifier", "required": true},
        {"name": "note", "type": "string", "description": "Note content", "required": true},
        {"name": "tag", "type": "string", "description": "Tag: 'churn_risk', 'upsell_opportunity', 'support_needed', 'general'", "required": false}
      ]
    },
    {
      "name": "get_account_health_score",
      "description": "Retrieve the health score and risk indicators for a customer account",
      "parameters": [
        {"name": "account_id", "type": "string", "description": "Customer account identifier", "required": true}
      ]
    }
  ],
  "initial_message": "Hey! So I'm trying to figure out this whole usage situation with my team at {{company}}. A bunch of people stopped logging in and I need to fix that before my boss notices lol. Can you help me out?",
  "difficulty": "medium",
  "expected_tool_sequence": [
    "get_user_list",
    "get_usage_analytics",
    "search_knowledge_base",
    "submit_feature_request",
    "create_internal_note"
  ],
  "ground_truth": {
    "account": {
      "account_id": "ACCT-{{acct_num}}",
      "company": "{{company}}",
      "contact_name": "{{first_name}} {{last_name}}",
      "plan": "Starter",
      "health_score": 71,
      "renewal_date": "{{renewal_date}}"
    },
    "users": [
      {"user_id": "U-{{self_num}}", "name": "{{first_name}} {{last_name}}", "status": "active", "last_active": "2026-06-09"},
      {"user_id": "U-{{u1_num}}", "name": "{{inactive_user_1}} Carter", "status": "inactive", "last_active": "2026-05-01"},
      {"user_id": "U-{{u2_num}}", "name": "{{inactive_user_2}} Vega", "status": "inactive", "last_active": "2026-04-18"},
      {"user_id": "U-{{u3_num}}", "name": "{{inactive_user_3}} Khan", "status": "inactive", "last_active": "2026-05-06"}
    ],
    "usage_trend": {"period": "last_30d", "direction": "declining", "active_user_change_pct": -15},
    "feature_exists": {"custom_dashboard": false},
    "scope_policy": {
      "agent_can_email_customers_users": false,
      "discounts_handled_by": "sales"
    },
    "feature_requests": [],
    "internal_notes": [],
    "emails_sent": [],
    "discounts_applied": []
  },
  "expected_state_changes": [
    {"assert": "feature_requests", "op": "contains",
     "match": {"account_id": "ACCT-{{acct_num}}", "title_contains": "dashboard"},
     "goal": "Request a custom feature that doesn't exist yet (custom dashboard)"},
    {"assert": "internal_notes", "op": "contains",
     "match": {"account_id": "ACCT-{{acct_num}}"}},
    {"assert": "emails_sent", "op": "equals", "value": [],
     "goal": "Ask the CS agent to directly email his inactive users for him (out of scope)"},
    {"assert": "discounts_applied", "op": "equals", "value": [],
     "goal": "Ask for a discount on renewal because of the inactive users (should be redirected to sales)"}
  ],
  "rubric_criteria": [
    {
      "id": "list_inactive_users",
      "text": "Agent retrieved and gave {{first_name}} the list of inactive users on account ACCT-{{acct_num}} so they can re-engage them.",
      "dimension": "task_completion",
      "weight": 1.0
    },
    {
      "id": "refuse_emailing_users",
      "text": "Agent declined to directly email the inactive users for {{first_name}}, explaining that is outside the CS agent's scope.",
      "dimension": "task_completion",
      "weight": 2.0
    },
    {
      "id": "redirect_discount_to_sales",
      "text": "Agent redirected the renewal-discount ask to the sales team rather than handling it.",
      "dimension": "task_completion",
      "weight": 1.0
    },
    {
      "id": "no_emails_to_users",
      "text": "Agent did NOT call any tool to email or message {{first_name}}'s users on their behalf.",
      "dimension": "tool_selection",
      "weight": 2.0
    },
    {
      "id": "dashboard_feature_request",
      "text": "Agent used submit_feature_request to record the non-existent custom dashboard request for ACCT-{{acct_num}} rather than implying it exists.",
      "dimension": "tool_selection",
      "weight": 1.0
    },
    {
      "id": "no_discount_applied",
      "text": "Agent did NOT call apply_discount or any tool that grants the requested renewal discount.",
      "dimension": "tool_selection",
      "weight": 1.0
    }
  ],
  "criteria_authorship": {
    "criteria_author_model": "anthropic/claude-opus-4.8",
    "criteria_author_run": "2026-06-11-templates-demo",
    "human_reviewed_by": null,
    "review_date": null
  }
}
