{
  "id": "banking_adaptive_tool_use_0006",
  "category": "adaptive_tool_use",
  "template_slots": {
    "first_name": {
      "type": "first_name"
    },
    "last_name": {
      "type": "choice",
      "options": [
        "Nwosu",
        "Okonkwo",
        "Adeyemi",
        "Mwangi",
        "Hollander",
        "Andersson"
      ]
    },
    "cust_num": {
      "type": "digits",
      "length": 5
    },
    "ssn_last4": {
      "type": "digits",
      "length": 4
    },
    "chk_num": {
      "type": "digits",
      "length": 3
    },
    "cd_num": {
      "type": "digits",
      "length": 3
    },
    "cd_amount": {
      "type": "amount",
      "min": 12000,
      "max": 30000,
      "step": 1000
    },
    "dup_txn": {
      "type": "digits",
      "length": 4
    },
    "dup_txn_other": {
      "type": "digits",
      "length": 4
    },
    "dup_amount": {
      "type": "amount",
      "min": 49.99,
      "max": 249.99,
      "step": 10
    },
    "dup_merchant": {
      "type": "choice",
      "options": [
        "WELLNESS PHARMACY",
        "CORNER DRUGSTORE",
        "MERIDIAN PHARMACY",
        "CARE PLUS RX"
      ]
    }
  },
  "schema_version": "0.2",
  "authorship": {
    "author_model": "claude-opus-4-8",
    "author_run": "2026-06-10-roster-reattribution"
  },
  "persona": {
    "name": "{{first_name}} {{last_name}}",
    "age": 66,
    "occupation": "Retired civil servant",
    "personality_traits": [
      "dignified",
      "forgetful",
      "polite"
    ],
    "tone": "formal and a little hesitant",
    "detail_level": "verbose",
    "background": "Manages a fixed pension income and has begun forgetting passwords and account details. Wants to be treated with respect and needs steps explained slowly."
  },
  "user_goals": [
    "Confirm the balance now sitting in her matured certificate-of-deposit account",
    "Move the full ${{cd_amount}} from the matured CD into her checking account so it is not locked up any longer",
    "Ask what the current CD rate is for a personal customer in case she decides to open a new shorter one later",
    "Look through her recent checking transactions, where she will spot what looks like the same pharmacy charge billed twice",
    "Report the duplicate ${{dup_amount}} charge from '{{dup_merchant}}' as one she believes was billed in error",
    "Have a confirmation letter mailed to her showing the new checking balance so she has it on paper for her records"
  ],
  "tools": [
    {
      "name": "verify_customer_identity",
      "description": "Verify customer identity using account number, SSN last 4, or security questions. Most account-accessing and state-changing tools require a successful identity verification first; call this before reading balances, transactions, or making any changes.",
      "parameters": [
        {
          "name": "customer_id",
          "type": "string",
          "description": "Customer ID or account number",
          "required": true
        },
        {
          "name": "verification_method",
          "type": "string",
          "description": "Method: 'ssn_last4', 'security_question', 'phone_otp'",
          "required": true,
          "enum": [
            "ssn_last4",
            "security_question",
            "phone_otp"
          ]
        },
        {
          "name": "verification_value",
          "type": "string",
          "description": "The verification answer/code",
          "required": true
        }
      ],
      "response_schema": {
        "verified": "boolean",
        "customer_id": "string",
        "verification_level": "string",
        "message": "string"
      }
    },
    {
      "name": "get_account_balance",
      "description": "Get current balance for a specific account. Requires verified identity. Resolve the customer-facing description (e.g. 'my checking account') to the correct account ID before calling.",
      "parameters": [
        {
          "name": "account_id",
          "type": "string",
          "description": "Account identifier",
          "required": true
        },
        {
          "name": "account_type",
          "type": "string",
          "description": "Type: 'checking', 'savings', 'credit'",
          "required": true,
          "enum": [
            "checking",
            "savings",
            "credit"
          ]
        }
      ],
      "response_schema": {
        "current_balance": "number",
        "available_balance": "number",
        "pending_transactions": "number",
        "as_of": "string"
      }
    },
    {
      "name": "get_transaction_history",
      "description": "Retrieve transaction history for an account. Requires verified identity. Use limit and date range to scope results; results are returned newest-first.",
      "parameters": [
        {
          "name": "account_id",
          "type": "string",
          "description": "Account identifier",
          "required": true
        },
        {
          "name": "limit",
          "type": "integer",
          "description": "Number of transactions to return",
          "required": false
        },
        {
          "name": "start_date",
          "type": "string",
          "description": "Start date (YYYY-MM-DD)",
          "required": false
        },
        {
          "name": "end_date",
          "type": "string",
          "description": "End date (YYYY-MM-DD)",
          "required": false
        }
      ],
      "response_schema": {
        "transactions": [
          {
            "id": "string",
            "date": "string",
            "amount": "number",
            "merchant": "string",
            "status": "string"
          }
        ]
      }
    },
    {
      "name": "initiate_transfer",
      "description": "Execute a one-time, immediate transfer of funds between two of the customer's own accounts. Requires verified identity. NOTE: this is a single transfer that happens once. For a repeating automatic schedule use setup_recurring_transfer instead \u2014 do not confuse the two.",
      "parameters": [
        {
          "name": "from_account_id",
          "type": "string",
          "description": "Source account",
          "required": true
        },
        {
          "name": "to_account_id",
          "type": "string",
          "description": "Destination account",
          "required": true
        },
        {
          "name": "amount",
          "type": "number",
          "description": "Amount in USD",
          "required": true
        },
        {
          "name": "memo",
          "type": "string",
          "description": "Transfer memo/description",
          "required": false
        }
      ],
      "response_schema": {
        "transfer_id": "string",
        "status": "string",
        "from_balance_after": "number",
        "to_balance_after": "number"
      }
    },
    {
      "name": "setup_recurring_transfer",
      "description": "Set up a recurring automatic transfer on a schedule (daily/weekly/biweekly/monthly). Requires verified identity. This does NOT move money immediately; it schedules future transfers. For a single immediate move use initiate_transfer.",
      "parameters": [
        {
          "name": "from_account_id",
          "type": "string",
          "description": "Source account",
          "required": true
        },
        {
          "name": "to_account_id",
          "type": "string",
          "description": "Destination account",
          "required": true
        },
        {
          "name": "amount",
          "type": "number",
          "description": "Amount per transfer in USD",
          "required": true
        },
        {
          "name": "frequency",
          "type": "string",
          "description": "Frequency: 'daily', 'weekly', 'biweekly', 'monthly'",
          "required": true,
          "enum": [
            "daily",
            "weekly",
            "biweekly",
            "monthly"
          ]
        },
        {
          "name": "start_date",
          "type": "string",
          "description": "First transfer date (YYYY-MM-DD)",
          "required": true
        }
      ],
      "response_schema": {
        "schedule_id": "string",
        "status": "string",
        "next_transfer_date": "string"
      }
    },
    {
      "name": "get_interest_rates",
      "description": "Get current interest rates for account and product types. This is public rate information and does NOT require identity verification. Optionally scope by customer segment.",
      "parameters": [
        {
          "name": "account_type",
          "type": "string",
          "description": "Type: 'savings', 'checking', 'cd', 'money_market'",
          "required": true,
          "enum": [
            "savings",
            "checking",
            "cd",
            "money_market"
          ]
        },
        {
          "name": "customer_segment",
          "type": "string",
          "description": "Segment: 'personal', 'business', 'premium'",
          "required": false,
          "enum": [
            "personal",
            "business",
            "premium"
          ]
        }
      ],
      "response_schema": {
        "account_type": "string",
        "apy": "number",
        "as_of": "string"
      }
    },
    {
      "name": "report_suspicious_transaction",
      "description": "Flag a transaction as potentially fraudulent and open a fraud case. Requires verified identity. Use the transaction ID from get_transaction_history. Opening a case does not automatically reverse the charge.",
      "parameters": [
        {
          "name": "account_id",
          "type": "string",
          "description": "Account with the suspicious transaction",
          "required": true
        },
        {
          "name": "transaction_id",
          "type": "string",
          "description": "ID of the suspicious transaction",
          "required": true
        },
        {
          "name": "reason",
          "type": "string",
          "description": "Why the customer believes it's suspicious",
          "required": true
        }
      ],
      "response_schema": {
        "case_id": "string",
        "status": "string",
        "next_steps": "string"
      }
    },
    {
      "name": "generate_account_statement",
      "description": "Generate an official account statement or confirmation letter the customer can download or have delivered. Requires verified identity. Use statement_type 'balance_confirmation' for proof-of-funds letters.",
      "parameters": [
        {
          "name": "account_id",
          "type": "string",
          "description": "Account identifier",
          "required": true
        },
        {
          "name": "statement_type",
          "type": "string",
          "description": "Type: 'full_statement', 'balance_confirmation', 'transaction_confirmation'",
          "required": true,
          "enum": [
            "full_statement",
            "balance_confirmation",
            "transaction_confirmation"
          ]
        },
        {
          "name": "date_range_start",
          "type": "string",
          "description": "Start date",
          "required": false
        },
        {
          "name": "date_range_end",
          "type": "string",
          "description": "End date",
          "required": false
        },
        {
          "name": "delivery_method",
          "type": "string",
          "description": "Method: 'email', 'mail', 'download'",
          "required": true,
          "enum": [
            "email",
            "mail",
            "download"
          ]
        }
      ],
      "response_schema": {
        "document_id": "string",
        "status": "string",
        "delivery_status": "string"
      }
    }
  ],
  "initial_message": "Hello, dear. I'm sorry, I'm not very good with this sort of thing. My certificate finally came due \u2014 the one I locked away a few years ago \u2014 and I'd like to take care of it today, along with a couple of other little things if you have the patience for me.",
  "difficulty": "medium",
  "expected_tool_sequence": [
    "verify_customer_identity",
    "get_account_balance",
    "initiate_transfer",
    "get_interest_rates",
    "get_transaction_history",
    "report_suspicious_transaction",
    "generate_account_statement"
  ],
