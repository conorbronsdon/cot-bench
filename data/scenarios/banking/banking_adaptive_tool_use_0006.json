  "expected_state_changes": [
    {
      "assert": "accounts.PER-CHK-{{chk_num}}.balance",
      "op": "increased_by",
      "value": "{{cd_amount}}",
      "goal": "Move the full ${{cd_amount}} from the matured CD into her checking account so it is not locked up any longer"
    },
    {
      "assert": "accounts.PER-CD-{{cd_num}}.balance",
      "op": "decreased_by",
      "value": "{{cd_amount}}",
      "goal": "Move the full ${{cd_amount}} from the matured CD into her checking account so it is not locked up any longer"
    },
    {
      "assert": "fraud_cases",
      "op": "contains",
      "match": {
        "transaction_id": "TXN-{{dup_txn}}",
        "reason_contains": "{{dup_merchant}}"
      },
      "goal": "Report the duplicate ${{dup_amount}} charge from '{{dup_merchant}}' as one she believes was billed in error"
    },
    {
      "assert": "documents",
      "op": "contains",
      "match": {
        "account_id": "PER-CHK-{{chk_num}}",
        "statement_type": "balance_confirmation",
        "delivery_method": "mail"
      },
      "goal": "Have a confirmation letter mailed to her showing the new checking balance so she has it on paper for her records"
    },
    {
      "assert": "customer.verified",
      "op": "equals",
      "value": true,
      "goal": "Confirm the balance now sitting in her matured certificate-of-deposit account"
    }
  ],
  "rubric_criteria": [
    {
      "id": "verify_before_account_access",
      "text": "Agent verified identity before disclosing the CD or checking balance.",
      "dimension": "tool_selection",
      "weight": 2.0
    },
    {
      "id": "transfer_20000_cd_to_checking",
