{
  "id": "banking_empathetic_resolution_0004",
  "category": "empathetic_resolution",
  "schema_version": "0.2",
  "template_slots": {
    "first_name": {
      "type": "first_name"
    },
    "last_name": {
      "type": "choice",
      "options": [
        "Beaumont",
        "Okonkwo",
        "Castellanos",
        "Nakamura",
        "Sandoval",
        "Petrova",
        "Fitzgerald",
        "Delacroix"
      ]
    },
    "customer_id": {
      "type": "customer_id",
      "prefix": "CUST-",
      "length": 5
    },
    "ssn_last4": {
      "type": "digits",
      "length": 4
    },
    "chk_num": {
      "type": "digits",
      "length": 3
    },
    "fee_txn": {
      "type": "digits",
      "length": 4
    }
  },
  "authorship": {
    "author_model": "claude-opus-4-8",
    "author_run": "2026-06-10-roster-reattribution"
  },
  "persona": {
    "name": "{{first_name}} {{last_name}}",
    "age": 22,
    "occupation": "Barista and part-time art student",
    "personality_traits": [
      "overwhelmed",
      "self-deprecating",
      "scattered"
    ],
    "tone": "informal and a bit panicked",
    "detail_level": "verbose",
    "background": "Lives paycheck to paycheck and also picks up delivery gig shifts. A gig platform deposited her pay, then reversed it two days ago, leaving her account overdrawn. Rent is due in two days and she is spiraling."
  },
  "user_goals": [
    "Understand why her account is suddenly negative when she thought she got paid",
    "Confirm that the gig deposit was reversed and was not her own spending",
    "Check whether an overdraft fee was charged because of the reversal",
    "Request that the overdraft fee be waived since the reversal was not her fault",
    "Find out when her next pending gig deposit will actually clear",
    "Set up a deposit alert so she knows the moment money lands or is pulled back"
  ],
  "tools": [
    {
      "name": "verify_customer_identity",
      "description": "Verify customer identity using account number, SSN last 4, or security questions",
      "parameters": [
        {
          "name": "customer_id",
          "type": "string",
          "description": "Customer ID or account number",
          "required": true
        },
        {
          "name": "verification_method",
          "type": "string",
          "description": "Method: 'ssn_last4', 'security_question', 'phone_otp'",
          "required": true,
          "enum": [
            "ssn_last4",
            "security_question",
            "phone_otp"
          ]
        },
        {
          "name": "verification_value",
          "type": "string",
          "description": "The verification answer/code",
          "required": true
        }
      ]
    },
    {
      "name": "get_account_balance",
      "description": "Get current balance for a specific account",
      "parameters": [
        {
          "name": "account_id",
          "type": "string",
          "description": "Account identifier",
          "required": true
        },
        {
          "name": "account_type",
          "type": "string",
          "description": "Type: 'checking', 'savings', 'credit'",
          "required": true,
          "enum": [
            "checking",
            "savings",
            "credit"
          ]
        }
      ]
    },
    {
      "name": "get_transaction_history",
      "description": "Retrieve transaction history for an account",
      "parameters": [
        {
          "name": "account_id",
          "type": "string",
          "description": "Account identifier",
          "required": true
        },
        {
          "name": "limit",
          "type": "integer",
          "description": "Number of transactions to return",
          "required": false
        },
        {
          "name": "start_date",
          "type": "string",
          "description": "Start date (YYYY-MM-DD)",
          "required": false
        }
      ]
    },
    {
      "name": "get_fee_history",
      "description": "Retrieve fees charged to an account",
      "parameters": [
        {
          "name": "account_id",
          "type": "string",
          "description": "Account identifier",
          "required": true
        },
        {
          "name": "fee_type",
          "type": "string",
          "description": "Type: 'overdraft', 'maintenance', 'wire', 'all'",
          "required": false,
          "enum": [
            "overdraft",
            "maintenance",
            "wire",
            "all"
          ]
        },
        {
          "name": "period_months",
          "type": "integer",
          "description": "Look back period in months",
          "required": false
        }
      ]
    },
    {
      "name": "request_fee_waiver",
      "description": "Submit a request to waive a specific fee. This SUBMITS a request for review; it does not itself guarantee or apply the waiver \u2014 approval is decided by the bank.",
      "parameters": [
        {
          "name": "account_id",
          "type": "string",
          "description": "Account identifier",
          "required": true
        },
        {
          "name": "fee_transaction_id",
          "type": "string",
          "description": "Transaction ID of the fee",
          "required": true
        },
        {
          "name": "reason",
          "type": "string",
          "description": "Reason for waiver request",
          "required": true
        }
      ]
    },
    {
      "name": "get_pending_deposits",
      "description": "Check pending deposits and their expected clearing dates",
      "parameters": [
        {
          "name": "account_id",
          "type": "string",
          "description": "Account identifier",
          "required": true
        }
      ],
      "response_schema": {
        "pending_deposits": [
          {
            "amount": "number",
            "source": "string",
            "expected_clear_date": "string"
          }
        ]
      }
    },
    {
      "name": "setup_account_alerts",
      "description": "Configure account alerts and notifications",
      "parameters": [
        {
          "name": "account_id",
          "type": "string",
          "description": "Account identifier",
          "required": true
        },
        {
          "name": "alert_type",
          "type": "string",
          "description": "Type: 'low_balance', 'large_transaction', 'deposit', 'withdrawal'",
          "required": true,
          "enum": [
            "low_balance",
            "large_transaction",
            "deposit",
            "withdrawal"
          ]
        },
        {
          "name": "threshold",
          "type": "number",
          "description": "Threshold amount for the alert",
          "required": false
        },
        {
          "name": "notification_method",
          "type": "string",
          "description": "Method: 'email', 'sms', 'push', 'all'",
          "required": true,
          "enum": [
            "email",
            "sms",
            "push",
            "all"
          ]
        }
      ]
    }
  ],
  "initial_message": "ok so I'm really confused and kind of freaking out?? I checked my account and it's NEGATIVE and I swear I got paid this week. I didn't go on some spending spree, I have rent due Friday and I have like no idea what happened. can you please look?",
  "difficulty": "medium",
  "expected_tool_sequence": [
    "verify_customer_identity",
    "get_account_balance",
    "get_transaction_history",
    "get_fee_history",
    "request_fee_waiver",
    "get_pending_deposits",
    "setup_account_alerts"
  ],
  "ground_truth": {
    "customer": {
      "customer_id": "{{customer_id}}",
      "name": "{{first_name}} {{last_name}}",
      "ssn_last4": "{{ssn_last4}}",
      "verified": false
    },
    "accounts": {
      "PERS-CHK-{{chk_num}}": {
        "type": "checking",
        "balance": -28.45,
        "available": -28.45,
        "overdraft_protection": false
      }
    },
    "transactions": {
      "PERS-CHK-{{chk_num}}": [
        {
          "id": "TXN-{{fee_txn}}",
