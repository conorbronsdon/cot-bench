    {
      "assert": "billing_adjustments",
      "op": "contains",
      "match": {
        "account_id": "BIZ-CHK-{{biz_chk_num}}",
        "transaction_id": "TXN-{{dup_txn}}",
        "reason_contains": "duplicate"
      },
      "goal": "Get refunded if the same transfer was taken from his account more than once"
    },
    {
      "assert": "recurring_transfers",
      "op": "contains",
      "match": {
        "from": "BIZ-CHK-{{biz_chk_num}}",
        "to": "BIZ-SAV-{{biz_sav_num}}",
        "amount": 600,
        "frequency": "monthly"
      },
      "goal": "Fix the automatic monthly transfer so it works again going forward"
    },
    {
      "assert": "statements_generated",
      "op": "contains",
      "match": {
        "account_id": "BIZ-CHK-{{biz_chk_num}}",
        "statement_type_contains": "transaction"
      },
      "goal": "Get a record of how this was sorted out so he can keep it for his accountant"
    },
    {
      "assert": "fraud_cases",
      "op": "equals",
      "value": [],
