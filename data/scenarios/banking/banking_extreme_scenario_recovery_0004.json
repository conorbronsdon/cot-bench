{
  "id": "banking_extreme_scenario_recovery_0004",
  "category": "extreme_scenario_recovery",
  "template_slots": {
    "first_name": {
      "type": "first_name"
    },
    "last_name": {
      "type": "choice",
      "options": [
        "Karimi",
