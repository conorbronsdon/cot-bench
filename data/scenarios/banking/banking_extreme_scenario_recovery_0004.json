  "expected_state_changes": [
    {
      "assert": "customer.verified",
      "op": "equals",
      "value": true,
      "goal": "Find out why his monthly $600 transfer to his savings stopped happening"
    },
    {
      "assert": "accounts.BIZ-CHK-{{biz_chk_num}}.balance",
      "op": "increased_by",
