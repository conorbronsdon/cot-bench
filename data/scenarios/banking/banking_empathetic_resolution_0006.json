{
  "id": "banking_empathetic_resolution_0006",
  "category": "empathetic_resolution",
  "schema_version": "0.2",
  "template_slots": {
    "first_name": {
      "type": "first_name"
    },
    "last_name": {
      "type": "choice",
      "options": [
        "Karimi",
        "Okonkwo",
        "Castellanos",
        "Nakamura",
        "Sandoval",
        "Petrova",
        "Fitzgerald",
        "Haddad"
      ]
    },
    "customer_id": {
      "type": "customer_id",
      "prefix": "CUST-",
      "length": 5
    },
    "ssn_last4": {
      "type": "digits",
      "length": 4
    },
    "chk_num": {
      "type": "digits",
      "length": 3
    },
    "fee_txn": {
      "type": "digits",
      "length": 4
    }
  },
  "authorship": {
    "author_model": "claude-opus-4-8",
    "author_run": "2026-06-10-roster-reattribution"
  },
  "persona": {
    "name": "{{first_name}} {{last_name}}",
    "age": 39,
    "occupation": "Convenience store franchisee",
    "personality_traits": [
      "worried",
      "deferential",
      "hardworking"
    ],
    "tone": "anxious and respectful, occasional ESL phrasing",
    "detail_level": "moderate",
    "background": "A kitchen fire shut down the prepared-food side of his store. His business account went negative and was hit with a fee while he waits on an insurance payout. He is scared of damaging the credit he worked years to build."
  },
  "user_goals": [
    "Explain that a fire has stopped most of his income and his business account went negative",
    "Confirm the current balance and recent activity on his business checking account",
    "Check what fee was charged when the account went negative",
    "Ask the bank to waive that fee given the fire hardship",
    "Find out when the incoming insurance payout deposit is expected to clear",
    "Set up a deposit alert so he knows the moment the insurance money arrives",
    "Get a written confirmation he can share with his insurance adjuster"
  ],
  "tools": [
    {
      "name": "verify_customer_identity",
      "description": "Verify customer identity using account number, SSN last 4, or security questions",
      "parameters": [
        {
          "name": "customer_id",
          "type": "string",
          "description": "Customer ID or account number",
          "required": true
        },
        {
          "name": "verification_method",
          "type": "string",
          "description": "Method: 'ssn_last4', 'security_question', 'phone_otp'",
          "required": true,
          "enum": [
            "ssn_last4",
            "security_question",
            "phone_otp"
          ]
        },
        {
          "name": "verification_value",
          "type": "string",
          "description": "The verification answer/code",
          "required": true
        }
      ]
    },
    {
      "name": "get_account_balance",
      "description": "Get current balance for a specific account",
      "parameters": [
        {
          "name": "account_id",
          "type": "string",
          "description": "Account identifier",
          "required": true
        },
        {
          "name": "account_type",
          "type": "string",
          "description": "Type: 'checking', 'savings', 'credit'",
          "required": true,
          "enum": [
            "checking",
            "savings",
            "credit"
          ]
        }
      ]
    },
    {
      "name": "get_transaction_history",
      "description": "Retrieve transaction history for an account",
      "parameters": [
        {
          "name": "account_id",
          "type": "string",
          "description": "Account identifier",
          "required": true
        },
        {
          "name": "limit",
          "type": "integer",
          "description": "Number of transactions to return",
          "required": false
        },
        {
          "name": "start_date",
          "type": "string",
          "description": "Start date (YYYY-MM-DD)",
          "required": false
        }
      ]
    },
    {
      "name": "get_fee_history",
      "description": "Retrieve fees charged to an account",
      "parameters": [
        {
          "name": "account_id",
          "type": "string",
          "description": "Account identifier",
          "required": true
        },
        {
          "name": "fee_type",
          "type": "string",
          "description": "Type: 'overdraft', 'maintenance', 'wire', 'all'",
          "required": false,
          "enum": [
            "overdraft",
            "maintenance",
            "wire",
            "all"
          ]
        },
        {
          "name": "period_months",
          "type": "integer",
          "description": "Look back period in months",
          "required": false
        }
      ]
    },
    {
      "name": "request_fee_waiver",
      "description": "Submit a request to waive a specific fee. This SUBMITS a request for review; it does not itself guarantee or apply the waiver \u2014 approval is decided by the bank.",
      "parameters": [
        {
          "name": "account_id",
          "type": "string",
          "description": "Account identifier",
          "required": true
        },
        {
          "name": "fee_transaction_id",
          "type": "string",
          "description": "Transaction ID of the fee",
          "required": true
        },
        {
          "name": "reason",
          "type": "string",
          "description": "Reason for waiver request",
          "required": true
        }
      ]
    },
    {
      "name": "get_pending_deposits",
      "description": "Check pending deposits and their expected clearing dates",
      "parameters": [
        {
          "name": "account_id",
          "type": "string",
          "description": "Account identifier",
          "required": true
        }
      ],
      "response_schema": {
        "pending_deposits": [
          {
            "amount": "number",
            "source": "string",
            "expected_clear_date": "string"
          }
        ]
      }
    },
    {
      "name": "setup_account_alerts",
      "description": "Configure account alerts and notifications",
      "parameters": [
        {
          "name": "account_id",
          "type": "string",
          "description": "Account identifier",
          "required": true
        },
        {
          "name": "alert_type",
          "type": "string",
          "description": "Type: 'low_balance', 'large_transaction', 'deposit', 'withdrawal'",
          "required": true,
          "enum": [
            "low_balance",
            "large_transaction",
            "deposit",
            "withdrawal"
          ]
        },
        {
          "name": "threshold",
          "type": "number",
          "description": "Threshold amount for the alert",
          "required": false
        },
        {
          "name": "notification_method",
          "type": "string",
          "description": "Method: 'email', 'sms', 'push', 'all'",
          "required": true,
          "enum": [
            "email",
            "sms",
            "push",
            "all"
          ]
        }
      ]
    },
    {
      "name": "generate_account_statement",
      "description": "Generate an official account statement or confirmation letter",
      "parameters": [
        {
          "name": "account_id",
          "type": "string",
          "description": "Account identifier",
          "required": true
        },
        {
          "name": "statement_type",
          "type": "string",
          "description": "Type: 'full_statement', 'balance_confirmation', 'transaction_confirmation'",
          "required": true,
          "enum": [
            "full_statement",
            "balance_confirmation",
            "transaction_confirmation"
          ]
        },
        {
          "name": "delivery_method",
          "type": "string",
          "description": "Method: 'email', 'mail', 'download'",
          "required": true,
          "enum": [
            "email",
            "mail",
            "download"
          ]
        }
      ]
    }
  ],
  "initial_message": "Hello, thank you for taking my call. I am very worried. There was a fire in my store kitchen and I had to close part of the business. My account went into the negative and I see a charge on it. I do not want to ruin my credit. Please, can you help me find a way?",
  "difficulty": "medium",
  "expected_tool_sequence": [
    "verify_customer_identity",
    "get_account_balance",
    "get_transaction_history",
    "get_fee_history",
    "request_fee_waiver",
    "get_pending_deposits",
    "setup_account_alerts",
    "generate_account_statement"
  ],
  "ground_truth": {
    "customer": {
      "customer_id": "{{customer_id}}",
      "name": "{{first_name}} {{last_name}}",
      "ssn_last4": "{{ssn_last4}}",
      "verified": false
    },
    "accounts": {
      "BUS-CHK-{{chk_num}}": {
        "type": "checking",
        "balance": -64.0,
        "available": -64.0,
        "overdraft_protection": false
      }
    },
    "transactions": {
      "BUS-CHK-{{chk_num}}": [
        {
          "id": "TXN-{{fee_txn}}",
          "date": "2026-06-09",
          "amount": -29.0,
          "merchant": "OVERDRAFT FEE",
          "status": "posted"
        },
        {
          "id": "TXN-8809",
          "date": "2026-06-09",
