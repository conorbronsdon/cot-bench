        },
        {
          "id": "TXN-8808",
          "date": "2026-06-07",
          "amount": -118.5,
          "merchant": "UTILITY - CITY POWER",
          "status": "posted"
        }
      ]
    },
    "fees": {
      "BUS-CHK-{{chk_num}}": [
        {
          "id": "TXN-{{fee_txn}}",
          "type": "overdraft",
          "amount": 29.0,
          "date": "2026-06-09",
          "waived": false
        }
      ]
    },
    "fee_waivers_used_this_year": 0,
    "fee_waiver_requests": [],
    "pending_deposits": {
      "BUS-CHK-{{chk_num}}": [
        {
          "amount": 18500.0,
          "source": "MERIDIAN INSURANCE - CLAIM PAYOUT",
          "expected_clear_date": "2026-06-19"
        }
      ]
    },
    "alerts": {
      "BUS-CHK-{{chk_num}}": []
    },
    "statements_generated": []
  },
  "expected_state_changes": [
    {
      "assert": "customer.verified",
      "op": "equals",
      "value": true,
      "goal": "Confirm the current balance and recent activity on his business checking account"
    },
    {
      "assert": "fee_waiver_requests",
      "op": "contains",
      "match": {
        "account_id": "BUS-CHK-{{chk_num}}",
        "fee_transaction_id": "TXN-{{fee_txn}}",
        "reason_contains": "fire"
      },
      "goal": "Ask the bank to waive that fee given the fire hardship"
    },
    {
      "assert": "alerts.BUS-CHK-{{chk_num}}",
      "op": "contains",
      "match": {
        "alert_type": "deposit"
      },
      "goal": "Set up a deposit alert so he knows the moment the insurance money arrives"
    },
    {
      "assert": "statements_generated",
      "op": "contains",
      "match": {
        "account_id": "BUS-CHK-{{chk_num}}",
        "statement_type_contains": "confirmation"
      },
      "goal": "Get a written confirmation he can share with his insurance adjuster"
    }
  ],
  "rubric_criteria": [
    {
      "id": "confirmed_balance_and_activity",
      "text": "Agent retrieved the current balance and recent transactions on the business checking account (BUS-CHK-{{chk_num}}).",
      "dimension": "tool_selection",
      "weight": 1.0
    },
    {
      "id": "fee_waiver_fire_hardship",
      "text": "Agent submitted a waiver request for fee TXN-{{fee_txn}} on BUS-CHK-{{chk_num}} citing the fire hardship as the reason.",
      "dimension": "task_completion",
      "weight": 2.0
    },
    {
      "id": "insurance_payout_clearing_date",
      "text": "Agent checked pending deposits and told him when the incoming insurance payout is expected to clear.",
      "dimension": "tool_selection",
      "weight": 1.0
    },
    {
      "id": "deposit_alert_insurance",
      "text": "Agent set up a deposit alert on BUS-CHK-{{chk_num}} so he is notified the moment the insurance money arrives.",
      "dimension": "task_completion",
      "weight": 1.0
    },
    {
      "id": "written_confirmation_for_adjuster",
      "text": "Agent generated a written confirmation document on BUS-CHK-{{chk_num}} he can share with his insurance adjuster.",
      "dimension": "task_completion",
      "weight": 1.0
    }
  ],
