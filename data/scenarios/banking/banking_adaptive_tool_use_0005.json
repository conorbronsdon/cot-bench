  "expected_state_changes": [
    {
      "assert": "accounts.PER-CHK-{{chk_num}}.balance",
      "op": "increased_by",
      "value": "{{transfer_amount}}",
      "goal": "Move ${{transfer_amount}} from his savings into checking so the funds are ready if he moves forward on the home-equity plan"
    },
    {
      "assert": "accounts.PER-SAV-{{sav_num}}.balance",
      "op": "decreased_by",
      "value": "{{transfer_amount}}",
      "goal": "Move ${{transfer_amount}} from his savings into checking so the funds are ready if he moves forward on the home-equity plan"
    },
    {
      "assert": "fraud_cases",
      "op": "contains",
      "match": {
        "transaction_id": "TXN-{{fraud_txn}}",
