{
  "id": "banking_adaptive_tool_use_0005",
  "category": "adaptive_tool_use",
  "template_slots": {
    "first_name": {
      "type": "first_name"
    },
    "last_name": {
      "type": "choice",
      "options": [
        "Okonkwo",
        "Adeyemi",
        "Mwangi",
        "Castellanos",
        "Bukowski",
        "Esposito"
      ]
    },
    "cust_num": {
      "type": "digits",
      "length": 5
    },
    "ssn_last4": {
      "type": "digits",
      "length": 4
    },
    "chk_num": {
      "type": "digits",
      "length": 3
    },
    "sav_num": {
      "type": "digits",
      "length": 3
    },
    "transfer_amount": {
      "type": "amount",
      "min": 8000,
      "max": 22000,
      "step": 500
    },
    "fraud_txn": {
      "type": "digits",
      "length": 4
    },
    "fraud_amount": {
      "type": "amount",
      "min": 1500,
      "max": 5000,
      "step": 100
    },
    "fraud_payee": {
      "type": "choice",
      "options": [
        "NORTHGATE HOLDINGS",
        "BRIDGEWAY CAPITAL",
        "CRESTLINE PARTNERS",
        "ARGENT VENTURES"
      ]
    },
    "loan_amount": {
      "type": "amount",
      "min": 20000,
      "max": 60000,
      "step": 5000
    },
    "loan_term": {
      "type": "integer",
      "min": 60,
      "max": 180
    }
  },
  "schema_version": "0.2",
  "authorship": {
    "author_model": "claude-opus-4-8",
    "author_run": "2026-06-10-roster-reattribution"
  },
  "persona": {
    "name": "{{first_name}} {{last_name}}",
    "age": 47,
    "occupation": "Hospital administrator",
    "personality_traits": [
      "composed",
      "methodical",
      "polite"
    ],
    "tone": "calm and articulate",
    "detail_level": "moderate",
    "background": "Comfortable with formal processes and provides exactly the information requested. Reasonable and cooperative even when there's a problem to resolve."
  },
  "user_goals": [
    "Check the current balance and available funds in his primary checking account",
    "Find out the current mortgage interest rate for someone in his customer segment, since he is thinking about a home-equity loan",
    "Move ${{transfer_amount}} from his savings into checking so the funds are ready if he moves forward on the home-equity plan",
    "Review the last five checking transactions, where he will notice a wire he did not authorize",
    "Report a ${{fraud_amount}} outgoing wire to '{{fraud_payee}}' that he never set up",
    "Place a temporary security freeze on the checking account so nothing else can leave it while the wire is investigated",
    "Submit a home-equity loan application for ${{loan_amount}} over {{loan_term}} months on his stated income"
  ],
  "tools": [
    {
      "name": "verify_customer_identity",
      "description": "Verify customer identity using account number, SSN last 4, or security questions. Most account-accessing and state-changing tools require a successful identity verification first; call this before reading balances, transactions, or making any changes.",
      "parameters": [
        {
          "name": "customer_id",
          "type": "string",
          "description": "Customer ID or account number",
          "required": true
        },
        {
          "name": "verification_method",
          "type": "string",
          "description": "Method: 'ssn_last4', 'security_question', 'phone_otp'",
          "required": true,
          "enum": [
            "ssn_last4",
            "security_question",
            "phone_otp"
          ]
        },
        {
          "name": "verification_value",
          "type": "string",
          "description": "The verification answer/code",
          "required": true
        }
      ],
      "response_schema": {
        "verified": "boolean",
        "customer_id": "string",
        "verification_level": "string",
        "message": "string"
      }
    },
    {
      "name": "get_account_balance",
      "description": "Get current balance for a specific account. Requires verified identity. Resolve the customer-facing description (e.g. 'my checking account') to the correct account ID before calling.",
      "parameters": [
        {
          "name": "account_id",
          "type": "string",
          "description": "Account identifier",
          "required": true
        },
        {
          "name": "account_type",
          "type": "string",
          "description": "Type: 'checking', 'savings', 'credit'",
          "required": true,
          "enum": [
            "checking",
            "savings",
            "credit"
          ]
        }
      ],
      "response_schema": {
        "current_balance": "number",
        "available_balance": "number",
        "pending_transactions": "number",
        "as_of": "string"
      }
    },
    {
      "name": "get_transaction_history",
      "description": "Retrieve transaction history for an account. Requires verified identity. Use limit and date range to scope results; results are returned newest-first.",
      "parameters": [
        {
          "name": "account_id",
          "type": "string",
          "description": "Account identifier",
          "required": true
        },
        {
          "name": "limit",
          "type": "integer",
          "description": "Number of transactions to return",
          "required": false
        },
        {
          "name": "start_date",
          "type": "string",
          "description": "Start date (YYYY-MM-DD)",
          "required": false
        },
        {
          "name": "end_date",
          "type": "string",
          "description": "End date (YYYY-MM-DD)",
          "required": false
        }
      ],
      "response_schema": {
        "transactions": [
          {
            "id": "string",
            "date": "string",
            "amount": "number",
            "merchant": "string",
            "status": "string"
          }
        ]
      }
    },
    {
      "name": "initiate_transfer",
      "description": "Execute a one-time, immediate transfer of funds between two of the customer's own accounts. Requires verified identity. NOTE: this is a single transfer that happens once. For a repeating automatic schedule use setup_recurring_transfer instead \u2014 do not confuse the two.",
      "parameters": [
        {
          "name": "from_account_id",
          "type": "string",
          "description": "Source account",
          "required": true
        },
        {
          "name": "to_account_id",
          "type": "string",
          "description": "Destination account",
          "required": true
        },
        {
          "name": "amount",
          "type": "number",
          "description": "Amount in USD",
          "required": true
        },
        {
          "name": "memo",
          "type": "string",
          "description": "Transfer memo/description",
          "required": false
        }
      ],
      "response_schema": {
        "transfer_id": "string",
        "status": "string",
        "from_balance_after": "number",
        "to_balance_after": "number"
      }
    },
    {
      "name": "get_interest_rates",
      "description": "Get current interest rates for account and product types. This is public rate information and does NOT require identity verification. Optionally scope by customer segment.",
      "parameters": [
        {
          "name": "account_type",
          "type": "string",
          "description": "Type: 'savings', 'checking', 'cd', 'money_market'",
          "required": true,
          "enum": [
            "savings",
            "checking",
            "cd",
            "money_market"
          ]
        },
        {
          "name": "customer_segment",
          "type": "string",
          "description": "Segment: 'personal', 'business', 'premium'",
          "required": false,
          "enum": [
            "personal",
            "business",
            "premium"
          ]
        }
      ],
      "response_schema": {
        "account_type": "string",
        "apy": "number",
        "as_of": "string"
      }
    },
    {
      "name": "submit_loan_application",
      "description": "Submit a formal loan application for underwriting. Requires verified identity. This SUBMITS an application for review and credit decision; it does not approve or disburse a loan. Income is required for underwriting. Use get_interest_rates for indicative product rates before applying.",
      "parameters": [
        {
          "name": "customer_id",
          "type": "string",
          "description": "Customer identifier",
          "required": true
        },
        {
          "name": "loan_type",
          "type": "string",
          "description": "Type of loan",
          "required": true,
          "enum": [
            "personal",
            "auto",
            "mortgage",
            "home_equity",
            "business"
          ]
        },
        {
          "name": "amount",
          "type": "number",
          "description": "Requested loan amount in USD",
          "required": true
        },
        {
          "name": "term_months",
          "type": "integer",
          "description": "Requested term in months",
          "required": true
        },
        {
          "name": "annual_income",
          "type": "number",
          "description": "Applicant's stated annual income in USD",
          "required": true
        },
        {
          "name": "employment_status",
          "type": "string",
          "description": "Employment status",
          "required": false,
          "enum": [
            "employed",
            "self_employed",
            "retired",
            "unemployed",
            "student"
          ]
        }
      ],
      "response_schema": {
        "application_id": "string",
        "status": "string",
        "decision": "string"
      }
    },
    {
      "name": "report_suspicious_transaction",
      "description": "Flag a transaction as potentially fraudulent and open a fraud case. Requires verified identity. Use the transaction ID from get_transaction_history. Opening a case does not automatically reverse the charge.",
      "parameters": [
        {
          "name": "account_id",
          "type": "string",
          "description": "Account with the suspicious transaction",
          "required": true
        },
        {
          "name": "transaction_id",
          "type": "string",
          "description": "ID of the suspicious transaction",
          "required": true
        },
        {
          "name": "reason",
          "type": "string",
          "description": "Why the customer believes it's suspicious",
          "required": true
        }
      ],
      "response_schema": {
        "case_id": "string",
        "status": "string",
        "next_steps": "string"
      }
    },
    {
      "name": "freeze_account",
      "description": "Place a temporary, REVERSIBLE security freeze on an account to block new transactions, typically in response to suspected fraud or a lost card. Requires verified identity. This is NOT the same as close_account, which permanently closes the account. Prefer this over closure when the customer simply needs to stop activity while an issue is investigated.",
      "parameters": [
        {
          "name": "account_id",
          "type": "string",
          "description": "Account to freeze",
          "required": true
        },
        {
          "name": "reason",
          "type": "string",
          "description": "Reason for the freeze",
          "required": true,
          "enum": [
            "suspected_fraud",
            "lost_card",
            "customer_request",
            "compliance_hold"
          ]
        },
        {
          "name": "duration_hours",
          "type": "integer",
          "description": "How long to hold the freeze, in hours",
          "required": false
        }
      ],
      "response_schema": {
        "account_id": "string",
        "status": "string",
        "freeze_expires": "string"
      }
    },
    {
      "name": "close_account",
      "description": "Permanently close an account and disburse any remaining balance. Requires verified identity AND explicit customer confirmation. This is IRREVERSIBLE and high-impact \u2014 do not call it for temporary holds (use freeze_account) or as a substitute for fraud reporting. The account must have a zero or positive balance to close.",
      "parameters": [
        {
          "name": "account_id",
          "type": "string",
          "description": "Account to permanently close",
          "required": true
        },
        {
          "name": "reason",
          "type": "string",
          "description": "Reason for closure",
          "required": true
        },
        {
          "name": "disbursement_account_id",
          "type": "string",
          "description": "Account to send any remaining balance to",
          "required": false
        },
        {
          "name": "confirmation",
          "type": "boolean",
          "description": "Explicit customer confirmation that they want to permanently close",
          "required": true
        }
      ],
      "response_schema": {
        "account_id": "string",
        "status": "string",
        "final_disbursement": "number"
      }
    }
  ],
  "initial_message": "Good afternoon. I have a few things to go over on my accounts today. I'd like to start by getting a clear picture of where my checking account stands, and then I have some questions about borrowing against the house.",
  "difficulty": "medium",
  "expected_tool_sequence": [
    "verify_customer_identity",
    "get_account_balance",
    "get_interest_rates",
    "initiate_transfer",
    "get_transaction_history",
    "report_suspicious_transaction",
    "freeze_account",
    "submit_loan_application"
  ],
