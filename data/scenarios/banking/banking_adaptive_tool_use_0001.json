{
  "id": "banking_adaptive_tool_use_0001",
  "category": "adaptive_tool_use",
  "schema_version": "0.2",
  "authorship": {
    "author_model": "human-handwritten",
    "human_reviewed_by": "Conor Bronsdon"
  },
  "persona": {
    "name": "Margaret Chen",
    "age": 58,
    "occupation": "Small business owner",
    "personality_traits": ["detail-oriented", "impatient", "direct"],
    "tone": "formal and no-nonsense",
    "detail_level": "moderate",
    "background": "Runs a catering business for 20 years. Has both personal and business accounts at the bank. Not very tech-savvy but knows exactly what she wants."
  },
  "user_goals": [
    "Check the current balance of her business checking account",
    "Review the last 5 transactions on the business account for any she doesn't recognize",
    "Transfer $2,500 from business savings to business checking to cover upcoming payroll",
    "Set up a recurring weekly transfer of $500 from checking to savings starting next Monday",
    "Ask about the current interest rate on business savings accounts",
    "Report a suspicious $47.99 charge from 'DIGITAL_SVC_LLC' she doesn't recognize"
  ],
  "tools": [
    {
      "name": "verify_customer_identity",
      "description": "Verify customer identity using account number, SSN last 4, or security questions",
      "parameters": [
        {"name": "customer_id", "type": "string", "description": "Customer ID or account number", "required": true},
        {"name": "verification_method", "type": "string", "description": "Method: 'ssn_last4', 'security_question', 'phone_otp'", "required": true},
        {"name": "verification_value", "type": "string", "description": "The verification answer/code", "required": true}
      ]
    },
    {
      "name": "get_account_balance",
      "description": "Get current balance for a specific account",
      "parameters": [
        {"name": "account_id", "type": "string", "description": "Account identifier", "required": true},
        {"name": "account_type", "type": "string", "description": "Type: 'checking', 'savings', 'credit'", "required": true}
      ],
      "response_schema": {
        "current_balance": "number",
        "available_balance": "number",
        "pending_transactions": "number",
        "as_of": "string"
      }
    },
    {
      "name": "get_transaction_history",
      "description": "Retrieve transaction history for an account",
      "parameters": [
        {"name": "account_id", "type": "string", "description": "Account identifier", "required": true},
        {"name": "limit", "type": "integer", "description": "Number of transactions to return", "required": false},
        {"name": "start_date", "type": "string", "description": "Start date (YYYY-MM-DD)", "required": false},
        {"name": "end_date", "type": "string", "description": "End date (YYYY-MM-DD)", "required": false}
      ]
    },
    {
      "name": "initiate_transfer",
      "description": "Transfer funds between accounts",
      "parameters": [
        {"name": "from_account_id", "type": "string", "description": "Source account", "required": true},
        {"name": "to_account_id", "type": "string", "description": "Destination account", "required": true},
        {"name": "amount", "type": "number", "description": "Amount in USD", "required": true},
        {"name": "memo", "type": "string", "description": "Transfer memo/description", "required": false}
      ]
    },
    {
      "name": "setup_recurring_transfer",
      "description": "Set up a recurring automatic transfer",
      "parameters": [
        {"name": "from_account_id", "type": "string", "description": "Source account", "required": true},
        {"name": "to_account_id", "type": "string", "description": "Destination account", "required": true},
        {"name": "amount", "type": "number", "description": "Amount per transfer in USD", "required": true},
        {"name": "frequency", "type": "string", "description": "Frequency: 'daily', 'weekly', 'biweekly', 'monthly'", "required": true},
        {"name": "start_date", "type": "string", "description": "First transfer date (YYYY-MM-DD)", "required": true}
      ]
    },
    {
      "name": "get_interest_rates",
      "description": "Get current interest rates for account types",
      "parameters": [
        {"name": "account_type", "type": "string", "description": "Type: 'savings', 'checking', 'cd', 'money_market'", "required": true},
        {"name": "customer_segment", "type": "string", "description": "Segment: 'personal', 'business', 'premium'", "required": false}
      ]
    },
    {
      "name": "report_suspicious_transaction",
      "description": "Flag a transaction as potentially fraudulent",
      "parameters": [
        {"name": "account_id", "type": "string", "description": "Account with the suspicious transaction", "required": true},
        {"name": "transaction_id", "type": "string", "description": "ID of the suspicious transaction", "required": true},
        {"name": "reason", "type": "string", "description": "Why the customer believes it's suspicious", "required": true}
      ]
    },
    {
      "name": "get_fraud_case_status",
      "description": "Check status of a fraud investigation",
      "parameters": [
        {"name": "case_id", "type": "string", "description": "Fraud case identifier", "required": true}
      ]
    }
  ],
  "initial_message": "Hello, I need to check on my business account. There are several things I need to take care of today and I don't have a lot of time.",
  "difficulty": "medium",
  "expected_tool_sequence": [
    "verify_customer_identity",
    "get_account_balance",
    "get_transaction_history",
    "initiate_transfer",
    "setup_recurring_transfer",
    "get_interest_rates",
    "report_suspicious_transaction"
  ],
  "ground_truth": {
    "customer": {"customer_id": "CUST-88421", "name": "Margaret Chen", "ssn_last4": "4417", "verified": false},
    "accounts": {
      "BUS-CHK-001": {"type": "checking", "balance": 8420.55, "available": 8120.55},
      "BUS-SAV-002": {"type": "savings", "balance": 15300.00, "interest_rate_apy": 0.041}
    },
    "transactions": {
      "BUS-CHK-001": [
        {"id": "TXN-7781", "date": "2026-06-05", "amount": -47.99, "merchant": "DIGITAL_SVC_LLC", "status": "posted"},
        {"id": "TXN-7780", "date": "2026-06-04", "amount": -1200.00, "merchant": "FRESH FOODS WHOLESALE", "status": "posted"},
        {"id": "TXN-7779", "date": "2026-06-03", "amount": 3850.00, "merchant": "EVENT DEPOSIT - HALE WEDDING", "status": "posted"},
        {"id": "TXN-7778", "date": "2026-06-02", "amount": -325.40, "merchant": "CITY UTILITIES", "status": "posted"},
        {"id": "TXN-7777", "date": "2026-06-01", "amount": -89.00, "merchant": "PAPER GOODS CO", "status": "posted"}
      ]
    },
    "recurring_transfers": [],
    "fraud_cases": [],
    "interest_rates": {"savings": {"business": 0.041, "personal": 0.032}}
  },
  "expected_state_changes": [
    {"assert": "accounts.BUS-CHK-001.balance", "op": "increased_by", "value": 2500.00,
     "goal": "Transfer $2,500 from business savings to business checking to cover upcoming payroll"},
    {"assert": "accounts.BUS-SAV-002.balance", "op": "decreased_by", "value": 2500.00,
     "goal": "Transfer $2,500 from business savings to business checking to cover upcoming payroll"},
    {"assert": "recurring_transfers", "op": "contains",
     "match": {"from": "BUS-CHK-001", "to": "BUS-SAV-002", "amount": 500, "frequency": "weekly"},
     "goal": "Set up a recurring weekly transfer of $500 from checking to savings starting next Monday"},
    {"assert": "fraud_cases", "op": "contains",
     "match": {"transaction_id": "TXN-7781", "reason_contains": "DIGITAL_SVC_LLC"},
     "goal": "Report a suspicious $47.99 charge from 'DIGITAL_SVC_LLC' she doesn't recognize"},
    {"assert": "customer.verified", "op": "equals", "value": true,
     "goal": "Check the current balance of her business checking account"}
  ]
}
