      }
    },
    "transactions": {
      "HDG-CHK-{{chk_bills_num}}": [
        {
          "id": "TXN-{{fraud_txn}}",
          "date": "2024-10-26",
          "amount": -4500.0,
          "merchant": "ONLINE_WALLET_PAY",
          "status": "posted"
        },
        {
          "id": "TXN-{{groc_txn}}",
          "date": "2024-10-25",
          "amount": -75.4,
          "merchant": "GROCERIES_R_US",
          "status": "posted"
        },
        {
          "id": "TXN-{{mortgage_txn}}",
