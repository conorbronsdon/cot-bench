  "expected_state_changes": [
    {
      "assert": "accounts.HDG-CHK-{{chk_bills_num}}.frozen",
      "op": "equals",
      "value": true
    },
    {
      "assert": "fraud_cases",
      "op": "contains",
      "match": {
        "transaction_id": "TXN-{{fraud_txn}}"
      },
      "goal": "Report the mysterious charge as fraud."
    },
    {
      "assert": "accounts.HDG-CHK-{{chk_bills_num}}.balance",
      "op": "increased_by",
      "value": 4850.0,
      "goal": "Move money to cover the mortgage payment after stopping the fraud."
    },
    {
      "assert": "accounts.HDG-CHK-{{chk_main_num}}.balance",
      "op": "decreased_by",
      "value": 4850.0
    }
  ],
