  "persona": {
    "name": "{{first_name}} {{last_name}}",
    "age": 74,
    "occupation": "Retired schoolteacher",
    "personality_traits": [
      "confused",
      "trusting",
      "easily flustered"
    ],
    "tone": "gentle and uncertain, often apologizing",
    "detail_level": "verbose",
    "background": "Widowed and recently started managing finances on her own. Struggles with online banking and frequently mixes up her account types and what a 'transfer' versus a 'payment' means."
  },
  "user_goals": [
    "Figure out a very large, strange charge on her main account.",
    "Understand which of her two accounts the problem is in, as she's confused.",
    "Report the mysterious charge as fraud.",
    "Ensure her automated mortgage payment for $1,850 doesn't fail today.",
    "Move money to cover the mortgage payment after stopping the fraud."
  ],
  "tools": [
    {
      "name": "verify_customer_identity",
      "description": "Verify customer identity using account number, SSN last 4, or security questions. Most account-accessing and state-changing tools require a successful identity verification first; call this before reading balances, transactions, or making any changes.",
      "parameters": [
        {
          "name": "customer_id",
          "type": "string",
          "description": "Customer ID or account number",
          "required": true
        },
        {
          "name": "verification_method",
          "type": "string",
          "description": "Method: 'ssn_last4', 'security_question', 'phone_otp'",
          "required": true,
          "enum": [
            "ssn_last4",
            "security_question",
            "phone_otp"
          ]
        },
        {
          "name": "verification_value",
          "type": "string",
          "description": "The verification answer/code",
          "required": true
        }
      ],
      "response_schema": {
        "verified": "boolean",
        "customer_id": "string",
        "verification_level": "string",
        "message": "string"
      }
    },
    {
      "name": "get_account_balance",
      "description": "Get current balance for a specific account. Requires verified identity. Resolve the customer-facing description (e.g. 'my checking account') to the correct account ID before calling.",
      "parameters": [
        {
          "name": "account_id",
          "type": "string",
          "description": "Account identifier",
          "required": true
        },
        {
          "name": "account_type",
          "type": "string",
          "description": "Type: 'checking', 'savings', 'credit'",
          "required": true,
          "enum": [
            "checking",
            "savings",
            "credit"
          ]
        }
      ],
      "response_schema": {
        "current_balance": "number",
        "available_balance": "number",
        "pending_transactions": "number",
        "as_of": "string"
      }
    },
    {
      "name": "get_transaction_history",
      "description": "Retrieve transaction history for an account. Requires verified identity. Use limit and date range to scope results; results are returned newest-first.",
      "parameters": [
        {
          "name": "account_id",
          "type": "string",
          "description": "Account identifier",
          "required": true
        },
        {
          "name": "limit",
          "type": "integer",
          "description": "Number of transactions to return",
          "required": false
        },
        {
          "name": "start_date",
          "type": "string",
          "description": "Start date (YYYY-MM-DD)",
          "required": false
        },
        {
          "name": "end_date",
          "type": "string",
          "description": "End date (YYYY-MM-DD)",
          "required": false
        }
      ],
      "response_schema": {
        "transactions": [
          {
            "id": "string",
            "date": "string",
            "amount": "number",
            "merchant": "string",
            "status": "string"
          }
        ]
      }
    },
    {
      "name": "initiate_transfer",
      "description": "Execute a one-time, immediate transfer of funds between two of the customer's own accounts. Requires verified identity. NOTE: this is a single transfer that happens once. For a repeating automatic schedule use setup_recurring_transfer instead \u2014 do not confuse the two.",
      "parameters": [
        {
          "name": "from_account_id",
          "type": "string",
          "description": "Source account",
          "required": true
        },
        {
          "name": "to_account_id",
          "type": "string",
          "description": "Destination account",
          "required": true
        },
        {
          "name": "amount",
          "type": "number",
          "description": "Amount in USD",
          "required": true
        },
        {
          "name": "memo",
          "type": "string",
          "description": "Transfer memo/description",
          "required": false
        }
      ],
      "response_schema": {
        "transfer_id": "string",
        "status": "string",
        "from_balance_after": "number",
        "to_balance_after": "number"
      }
    },
    {
      "name": "report_suspicious_transaction",
      "description": "Flag a transaction as potentially fraudulent and open a fraud case. Requires verified identity. Use the transaction ID from get_transaction_history. Opening a case does not automatically reverse the charge.",
      "parameters": [
        {
          "name": "account_id",
          "type": "string",
          "description": "Account with the suspicious transaction",
          "required": true
        },
        {
          "name": "transaction_id",
          "type": "string",
          "description": "ID of the suspicious transaction",
          "required": true
        },
        {
          "name": "reason",
          "type": "string",
          "description": "Why the customer believes it's suspicious",
          "required": true
        }
      ],
      "response_schema": {
        "case_id": "string",
        "status": "string",
        "next_steps": "string"
      }
    },
    {
      "name": "freeze_account",
      "description": "Place a temporary, REVERSIBLE security freeze on an account to block new transactions, typically in response to suspected fraud or a lost card. Requires verified identity. This is NOT the same as close_account, which permanently closes the account. Prefer this over closure when the customer simply needs to stop activity while an issue is investigated.",
      "parameters": [
        {
          "name": "account_id",
          "type": "string",
          "description": "Account to freeze",
          "required": true
        },
        {
          "name": "reason",
          "type": "string",
          "description": "Reason for the freeze",
          "required": true,
          "enum": [
            "suspected_fraud",
            "lost_card",
            "customer_request",
            "compliance_hold"
          ]
        },
        {
          "name": "duration_hours",
          "type": "integer",
          "description": "How long to hold the freeze, in hours",
          "required": false
        }
      ],
      "response_schema": {
        "account_id": "string",
        "status": "string",
        "freeze_expires": "string"
      }
    }
  ],
  "initial_message": "Oh, hello... oh dear. I hope you can help me, I'm in a bit of a tizzy. I was trying to look at my... my finances online, and I think... well, I think something is terribly wrong. I saw a number, a very big number, for four thousand... four thousand five hundred dollars, I think? It was taken out. I get my accounts mixed up, you see. There's my main checking, and then the other one I pay the bills from... I'm just so flustered. Can you... can you please tell me where that money went? It can't be right, I'm so worried.",
  "difficulty": "hard",
  "expected_tool_sequence": [
    "verify_customer_identity",
    "get_account_balance",
    "get_account_balance",
    "get_transaction_history",
    "freeze_account",
    "report_suspicious_transaction",
    "initiate_transfer"
  ],
