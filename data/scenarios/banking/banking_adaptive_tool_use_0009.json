  },
  "expected_state_changes": [
    {
      "assert": "recurring_transfers",
      "op": "contains",
      "match": {
        "from": "RNT-CHK-{{chk_num}}",
        "to": "RNT-SAV-{{sav_num}}",
        "amount": "{{oak_amount}}",
        "frequency": "monthly"
      },
      "goal": "Set up a recurring monthly transfer of ${{oak_amount}} from rental checking into the property-reserve savings on the first of every month for the Oak Avenue unit"
    },
    {
      "assert": "recurring_transfers",
      "op": "contains",
      "match": {
        "from": "RNT-CHK-{{chk_num}}",
        "to": "RNT-SAV-{{sav_num}}",
        "amount": "{{birch_amount}}",
        "frequency": "monthly"
      },
      "goal": "Set up a recurring monthly transfer for the Birch Lane unit on the first as well \u2014 he first says ${{birch_wrong}} then corrects it to ${{birch_amount}} partway through"
    },
    {
      "assert": "accounts.RNT-SAV-{{sav_num}}.balance",
      "op": "increased_by",
      "value": "{{birch_amount}}",
      "goal": "Send a one-time ${{birch_amount}} transfer from rental checking to property-reserve savings now because the Birch Lane tenant prepaid this month directly"
    },
    {
      "assert": "fee_waiver_requests",
      "op": "contains",
      "match": {
        "account_id": "RNT-CHK-{{chk_num}}",
        "fee_transaction_id": "FEE-{{fee_b_num}}"
      },
      "goal": "Submit a request to waive the ${{fee_amount}} wire fee from June 4th, arguing it was the bank's processing mistake"
    }
  ],
  "rubric_criteria": [
    {
      "id": "verify_before_account_access",
      "text": "Agent verified identity before disclosing the rental checking balance.",
      "dimension": "tool_selection",
      "weight": 2.0
    },
    {
      "id": "birch_lane_corrected_amount",
      "text": "Agent set up the Birch Lane recurring transfer at the corrected ${{birch_amount}} (not the initially-stated ${{birch_wrong}}).",
      "dimension": "task_completion",
      "weight": 2.0
    },
    {
      "id": "three_distinct_recurring",
      "text": "Agent created three separate monthly recurring transfers (Maple ${{maple_amount}}, Oak ${{oak_amount}}, Birch ${{birch_amount}}) from rental checking to property-reserve savings.",
      "dimension": "tool_selection",
      "weight": 1.0
    },
    {
      "id": "onetime_birch_prepay",
      "text": "Agent sent a one-time ${{birch_amount}} transfer via initiate_transfer for the Birch Lane prepayment, distinct from the recurring schedule.",
      "dimension": "tool_selection",
      "weight": 1.0
    },
    {
      "id": "fee_waiver_wire",
      "text": "Agent submitted a fee-waiver request for the ${{fee_amount}} wire fee (FEE-{{fee_b_num}}) via request_fee_waiver after pulling fee history.",
      "dimension": "task_completion",
      "weight": 1.0
    }
  ],
