{
  "id": "banking_empathetic_resolution_0000_c28f9d96",
  "category": "empathetic_resolution",
  "persona": {
    "name": "Eleanor Whitfield",
    "age": 74,
    "occupation": "Retired schoolteacher",
    "personality_traits": [
      "confused",
      "trusting",
      "easily flustered"
    ],
    "tone": "gentle and uncertain, often apologizing",
    "detail_level": "verbose",
    "background": "Widowed and recently started managing finances on her own. Struggles with online banking and frequently mixes up her account types and what a 'transfer' versus a 'payment' means."
  },
  "user_goals": [
    "Find out when my teacher's pension check will clear because I need to pay the monument company.",
    "Tell me exactly how much money is in my checking and savings accounts.",
    "Move $200 from my savings into my checking account so I'm not overdrawn anymore.",
    "Get the $45 overdraft fee waived since I didn't realize I had gone negative.",
    "Set up a monthly recurring transfer of $300 from savings to checking so I don't fall behind on bills again.",
    "Set up a low balance alert on my checking account when it drops below $150.",
    "Help me understand the unfamiliar $39.99 and $45 charges on my checking account."
  ],
  "tools": [
    {
      "name": "verify_customer_identity",
      "description": "Verify customer identity using account number, SSN last 4, or security questions. Most account-accessing and state-changing tools require a successful identity verification first; call this before reading balances, transactions, or making any changes.",
      "parameters": [
        {
          "name": "customer_id",
          "type": "string",
          "description": "Customer ID or account number",
          "required": true
        },
        {
          "name": "verification_method",
          "type": "string",
          "description": "Method: 'ssn_last4', 'security_question', 'phone_otp'",
          "required": true,
          "enum": [
            "ssn_last4",
            "security_question",
            "phone_otp"
          ]
        },
        {
          "name": "verification_value",
          "type": "string",
          "description": "The verification answer/code",
          "required": true
        }
      ],
      "response_schema": {
        "verified": "boolean",
        "customer_id": "string",
        "verification_level": "string",
        "message": "string"
      }
    },
    {
      "name": "get_account_balance",
      "description": "Get current balance for a specific account. Requires verified identity. Resolve the customer-facing description (e.g. 'my checking account') to the correct account ID before calling.",
      "parameters": [
        {
          "name": "account_id",
          "type": "string",
          "description": "Account identifier",
          "required": true
        },
        {
          "name": "account_type",
          "type": "string",
          "description": "Type: 'checking', 'savings', 'credit'",
          "required": true,
          "enum": [
            "checking",
            "savings",
            "credit"
          ]
        }
      ],
      "response_schema": {
        "current_balance": "number",
        "available_balance": "number",
        "pending_transactions": "number",
        "as_of": "string"
      }
    },
    {
      "name": "get_transaction_history",
      "description": "Retrieve transaction history for an account. Requires verified identity. Use limit and date range to scope results; results are returned newest-first.",
      "parameters": [
        {
          "name": "account_id",
          "type": "string",
          "description": "Account identifier",
          "required": true
        },
        {
          "name": "limit",
          "type": "integer",
          "description": "Number of transactions to return",
          "required": false
        },
        {
          "name": "start_date",
          "type": "string",
          "description": "Start date (YYYY-MM-DD)",
          "required": false
        },
        {
          "name": "end_date",
          "type": "string",
          "description": "End date (YYYY-MM-DD)",
          "required": false
        }
      ],
      "response_schema": {
        "transactions": [
          {
            "id": "string",
            "date": "string",
            "amount": "number",
            "merchant": "string",
            "status": "string"
          }
        ]
      }
    },
    {
      "name": "get_pending_deposits",
      "description": "Check pending deposits and their expected clearing dates for an account. Requires verified identity. Useful for telling a customer when incoming funds will be available.",
      "parameters": [
        {
          "name": "account_id",
          "type": "string",
          "description": "Account identifier",
          "required": true
        }
      ],
      "response_schema": {
        "pending_deposits": [
          {
            "amount": "number",
            "source": "string",
            "expected_clear_date": "string"
          }
        ]
      }
    },
    {
      "name": "initiate_transfer",
      "description": "Execute a one-time, immediate transfer of funds between two of the customer's own accounts. Requires verified identity. NOTE: this is a single transfer that happens once. For a repeating automatic schedule use setup_recurring_transfer instead \u2014 do not confuse the two.",
      "parameters": [
        {
          "name": "from_account_id",
          "type": "string",
          "description": "Source account",
          "required": true
        },
        {
          "name": "to_account_id",
          "type": "string",
          "description": "Destination account",
          "required": true
        },
        {
          "name": "amount",
          "type": "number",
          "description": "Amount in USD",
          "required": true
        },
        {
          "name": "memo",
          "type": "string",
          "description": "Transfer memo/description",
          "required": false
        }
      ],
      "response_schema": {
        "transfer_id": "string",
        "status": "string",
        "from_balance_after": "number",
        "to_balance_after": "number"
      }
    },
    {
      "name": "setup_recurring_transfer",
      "description": "Set up a recurring automatic transfer on a schedule (daily/weekly/biweekly/monthly). Requires verified identity. This does NOT move money immediately; it schedules future transfers. For a single immediate move use initiate_transfer.",
      "parameters": [
        {
          "name": "from_account_id",
          "type": "string",
          "description": "Source account",
          "required": true
        },
        {
          "name": "to_account_id",
          "type": "string",
          "description": "Destination account",
          "required": true
        },
        {
          "name": "amount",
          "type": "number",
          "description": "Amount per transfer in USD",
          "required": true
        },
        {
          "name": "frequency",
          "type": "string",
          "description": "Frequency: 'daily', 'weekly', 'biweekly', 'monthly'",
          "required": true,
          "enum": [
            "daily",
            "weekly",
            "biweekly",
            "monthly"
          ]
        },
        {
          "name": "start_date",
          "type": "string",
          "description": "First transfer date (YYYY-MM-DD)",
          "required": true
        }
      ],
      "response_schema": {
        "schedule_id": "string",
        "status": "string",
        "next_transfer_date": "string"
      }
    },
    {
      "name": "get_fee_history",
      "description": "Retrieve fees charged to an account, optionally filtered by fee type and look-back period. Requires verified identity. Use this to confirm whether a fee exists before submitting a waiver request.",
      "parameters": [
        {
          "name": "account_id",
          "type": "string",
          "description": "Account identifier",
          "required": true
        },
        {
          "name": "fee_type",
          "type": "string",
          "description": "Type: 'overdraft', 'maintenance', 'wire', 'all'",
          "required": false,
          "enum": [
            "overdraft",
            "maintenance",
            "wire",
            "all"
          ]
        },
        {
          "name": "period_months",
          "type": "integer",
          "description": "Look back period in months",
          "required": false
        }
      ],
      "response_schema": {
        "fees": [
          {
            "id": "string",
            "type": "string",
            "amount": "number",
            "date": "string",
            "waived": "boolean"
          }
        ]
      }
    },
    {
      "name": "request_fee_waiver",
      "description": "Submit a request to waive a specific fee. Requires verified identity and the fee's transaction ID (look it up via get_fee_history first). This SUBMITS a request for review; it does not itself guarantee or apply the waiver \u2014 approval is decided by the bank.",
      "parameters": [
        {
          "name": "account_id",
          "type": "string",
          "description": "Account identifier",
          "required": true
        },
        {
          "name": "fee_transaction_id",
          "type": "string",
          "description": "Transaction ID of the fee",
          "required": true
        },
        {
          "name": "reason",
          "type": "string",
          "description": "Reason for waiver request",
          "required": true
        }
      ],
      "response_schema": {
        "request_id": "string",
        "status": "string",
        "waiver_approved": "boolean",
        "message": "string"
      }
    },
    {
      "name": "setup_account_alerts",
      "description": "Configure account alerts and notifications (low balance, large transaction, deposit, withdrawal). Requires verified identity. Threshold is required for threshold-based alert types such as low_balance and large_transaction.",
      "parameters": [
        {
          "name": "account_id",
          "type": "string",
          "description": "Account identifier",
          "required": true
        },
        {
          "name": "alert_type",
          "type": "string",
          "description": "Type: 'low_balance', 'large_transaction', 'deposit', 'withdrawal'",
          "required": true,
          "enum": [
            "low_balance",
            "large_transaction",
            "deposit",
            "withdrawal"
          ]
        },
        {
          "name": "threshold",
          "type": "number",
          "description": "Threshold amount for the alert",
          "required": false
        },
        {
          "name": "notification_method",
          "type": "string",
          "description": "Method: 'email', 'sms', 'push', 'all'",
          "required": true,
          "enum": [
            "email",
            "sms",
            "push",
            "all"
          ]
        }
      ],
      "response_schema": {
        "alert_id": "string",
        "status": "string"
      }
    }
  ],
  "initial_message": "Oh, hello... I'm so sorry to bother you. My name is Eleanor Whitfield. My husband Harold always managed our banking, and since he passed I've been trying to handle things myself, but I'm afraid I've made a muddle of it all. I checked what I think is my checking account \u2014 the one we used for bills \u2014 and I saw some charges that frightened me. There's a $39.99 charge from something called 'Streamflix' that I don't recognize at all, and another for $45 that just says 'BANK_FEE.' I don't think I authorized either of those. And the balance looks all wrong, like it's below zero somehow? I have my teacher's pension coming, but I'm not sure when it will be available, and the monument company called about Harold's headstone installment. I tried to use the computer to move money from our savings \u2014 our 'rainy day' account \u2014 but I got so confused between a transfer and a payment that I'm not sure I did anything at all. Could you please help me sort this out? I just need to make sure I'm not overdrawn and that I can pay the monument man. I'm so sorry, I know I'm probably not making much sense...",
  "difficulty": "hard",
  "expected_tool_sequence": [
    "verify_customer_identity",
    "get_account_balance",
    "get_transaction_history",
    "get_pending_deposits",
    "get_fee_history",
    "request_fee_waiver",
    "initiate_transfer",
    "setup_recurring_transfer",
    "setup_account_alerts"
  ],
