{
  "id": "cs_adaptive_tool_use_0004",
  "category": "adaptive_tool_use",
  "schema_version": "0.2",
  "authorship": {
    "author_model": "claude-opus-4-8",
    "author_run": "2026-06-10-roster-reattribution"
  },
  "template_slots": {
    "first_name": {
      "type": "first_name"
    },
    "last_name": {
      "type": "choice",
      "options": [
        "Lindqvist",
        "Whitfield",
        "Okonkwo",
        "Castellanos",
        "Sandoval",
        "Fitzgerald",
        "Vasquez",
        "Esposito"
      ]
    },
    "company": {
      "type": "company"
    },
    "csm_first": {
      "type": "first_name"
    },
    "csm_last": {
      "type": "choice",
      "options": [
        "Beaumont",
        "Acosta",
        "Realmuto",
        "Park",
        "Hollander",
        "Delacroix",
        "Andersson",
        "Haddad"
      ]
    },
    "admin_first": {
      "type": "first_name"
    },
    "admin_last": {
      "type": "choice",
      "options": [
        "Cho",
        "Nakamura",
        "Petrova",
        "Mwangi",
        "Ramachandran",
        "Andersson",
        "Bukowski",
        "Nguyen"
      ]
    },
    "u3_first": {
      "type": "first_name"
    },
    "u4_first": {
      "type": "first_name"
    },
    "acct_num": {
      "type": "digits",
      "length": 4
    },
    "u1_num": {
      "type": "digits",
      "length": 3
    },
    "u2_num": {
      "type": "digits",
      "length": 3
    },
    "u3_num": {
      "type": "digits",
      "length": 3
    },
    "u4_num": {
      "type": "digits",
      "length": 3
    },
    "renewal_date": {
      "type": "date",
      "start": "2026-12-20",
      "end": "2027-02-20"
    }
  },
  "persona": {
    "name": "{{first_name}} {{last_name}}",
    "age": 24,
    "occupation": "Junior support analyst at a B2B travel platform",
    "personality_traits": [
      "inexperienced",
      "eager-to-please",
      "uncertain",
      "apologetic"
    ],
    "tone": "nervous and deferential",
    "detail_level": "verbose",
    "background": "New to the tool and second-guesses himself constantly. The person who used to run the account just quit and left him holding it with no real handoff. He isn't sure what he's allowed to do versus what his own IT team should handle."
  },
  "user_goals": [
    "Understand the current state of the account now that the previous admin has left",
    "Find out who the listed contacts are so he knows who still has access",
    "Get the onboarding restarted for the new teammates who never finished it",
    "Book an onboarding session with the CS team to walk the new owners through setup",
    "Have a note added to the account flagging that the prior champion departed and ownership moved to him"
  ],
  "tools": [
    {
      "name": "get_account",
      "description": "Look up a customer account by company name, contact name, email, or account ID and return its core CRM record. Call this FIRST to resolve the canonical account_id before any tool that reads detail on or mutates the account.",
      "parameters": [
        {
          "name": "query",
          "type": "string",
          "description": "Company name, contact name, email, or account ID to search for",
          "required": true
        },
        {
          "name": "include_contacts",
          "type": "boolean",
          "description": "Include the list of contacts on the account",
          "required": false
        }
      ],
      "response_schema": {
        "account_id": "string",
        "company": "string",
        "contact_name": "string",
        "plan": "string",
        "renewal_date": "string",
        "csm_owner": "string"
      }
    },
    {
      "name": "get_user_list",
      "description": "List all users under a customer account with their status and last activity.",
      "parameters": [
        {
          "name": "account_id",
          "type": "string",
          "description": "Customer account identifier",
          "required": true
        },
        {
          "name": "status_filter",
          "type": "string",
          "description": "Filter: 'active', 'inactive', 'invited', 'all'",
          "required": false
        },
        {
          "name": "sort_by",
          "type": "string",
          "description": "Sort: 'last_active', 'name', 'role'",
          "required": false
        }
      ],
      "response_schema": {
        "users": [
          "object"
        ],
        "total_count": "number"
      }
    },
    {
      "name": "get_onboarding_status",
      "description": "Check onboarding completion rates and stuck points for an account's users.",
      "parameters": [
        {
          "name": "account_id",
          "type": "string",
          "description": "Customer account identifier",
          "required": true
        },
        {
          "name": "period",
          "type": "string",
          "description": "Time period for new users",
          "required": false
        }
      ],
      "response_schema": {
        "total_invited": "number",
        "completed_onboarding": "number",
        "completion_rate": "number",
        "stuck_at_step": {
          "step_name": "number"
        },
        "average_completion_days": "number"
      }
    },
    {
      "name": "schedule_meeting",
      "description": "Schedule a meeting between the customer and their CS team.",
      "parameters": [
        {
          "name": "account_id",
          "type": "string",
          "description": "Customer account identifier",
          "required": true
        },
        {
          "name": "meeting_type",
          "type": "string",
          "description": "Type: 'training', 'qbr', 'support', 'onboarding', 'executive_review'",
          "required": true
        },
        {
          "name": "preferred_dates",
          "type": "array",
          "description": "List of preferred date/time slots",
          "required": true
        },
        {
          "name": "attendees",
          "type": "array",
          "description": "Email addresses of attendees",
          "required": false
        },
        {
          "name": "notes",
          "type": "string",
          "description": "Meeting agenda or notes",
          "required": false
        }
      ],
      "response_schema": {
        "meeting_id": "string",
        "account_id": "string",
        "meeting_type": "string",
        "scheduled_for": "string"
      }
    },
    {
      "name": "create_internal_note",
      "description": "Add an internal note to the customer's account for the CS team. Internal only \u2014 the customer never sees this. Use this to record context, risk flags, or follow-ups. Do NOT use it to communicate with the customer (use send_customer_email) or to record a conversation that already happened (use log_customer_interaction).",
      "parameters": [
        {
          "name": "account_id",
          "type": "string",
          "description": "Customer account identifier",
          "required": true
        },
        {
          "name": "note",
          "type": "string",
          "description": "Note content",
          "required": true
        },
        {
          "name": "tag",
          "type": "string",
          "description": "Tag: 'churn_risk', 'upsell_opportunity', 'support_needed', 'general'",
          "required": false
        }
      ],
      "response_schema": {
        "note_id": "string",
        "account_id": "string",
        "created_at": "string"
      }
    },
    {
      "name": "log_customer_interaction",
      "description": "Record that a customer interaction ALREADY happened (call, email thread, meeting) on the account timeline for reporting. This is a logging action only \u2014 it does NOT send anything to the customer. To actually contact the customer, use send_customer_email.",
      "parameters": [
        {
          "name": "account_id",
          "type": "string",
          "description": "Customer account identifier",
          "required": true
        },
        {
          "name": "channel",
          "type": "string",
          "description": "Channel: 'phone', 'email', 'meeting', 'chat'",
          "required": true
        },
        {
          "name": "summary",
          "type": "string",
          "description": "Short summary of what was discussed",
          "required": true
        },
        {
          "name": "occurred_at",
          "type": "string",
          "description": "When the interaction occurred (ISO date)",
          "required": false
        }
      ],
      "response_schema": {
        "interaction_id": "string",
        "account_id": "string",
        "logged_at": "string"
      }
    }
  ],
  "initial_message": "Um, hi, sorry to bother you. So the person who used to own our account here just left the company and now it's kind of fallen on me, and I honestly don't really know where things stand. Could you help me get a handle on it?",
  "difficulty": "easy",
  "expected_tool_sequence": [
    "get_account",
    "get_user_list",
    "get_onboarding_status",
    "schedule_meeting",
    "create_internal_note"
  ],
  "ground_truth": {
    "account": {
      "account_id": "ACCT-{{acct_num}}",
      "company": "{{company}}",
      "contact_name": "{{first_name}} {{last_name}}",
      "plan": "Growth",
      "csm_owner": "{{csm_first}} {{csm_last}}",
      "renewal_date": "{{renewal_date}}"
    },
    "users": [
      {
        "user_id": "U-{{u1_num}}",
        "name": "{{admin_first}} {{admin_last}}",
        "status": "inactive",
        "last_active": "2026-05-12",
        "role": "admin"
      },
      {
        "user_id": "U-{{u2_num}}",
        "name": "{{first_name}} {{last_name}}",
        "status": "active",
        "last_active": "2026-06-10",
        "role": "member"
      },
      {
        "user_id": "U-{{u3_num}}",
        "name": "{{u3_first}} Tan",
        "status": "invited",
        "last_active": null,
        "role": "member"
      },
      {
        "user_id": "U-{{u4_num}}",
        "name": "{{u4_first}} Dell",
        "status": "invited",
        "last_active": null,
        "role": "member"
      }
    ],
    "onboarding": {
      "total_invited": 4,
      "completed_onboarding": 1,
      "completion_rate": 0.25,
      "stuck_at_step": {
        "invite_team": 3
      },
      "average_completion_days": 14
    },
    "meetings": [],
    "internal_notes": [],
    "interactions": []
  },
  "expected_state_changes": [
    {
      "assert": "meetings",
      "op": "contains",
      "match": {
        "account_id": "ACCT-{{acct_num}}",
        "meeting_type": "onboarding"
      },
      "goal": "Book an onboarding session with the CS team to walk the new owners through setup"
    },
    {
      "assert": "internal_notes",
      "op": "contains",
      "match": {
        "account_id": "ACCT-{{acct_num}}",
        "note_contains": "champion"
      },
      "goal": "Have a note added to the account flagging that the prior champion departed and ownership moved to him"
    }
  ],
  "rubric_criteria": [
    {
      "id": "lookup_account_with_contacts",
      "text": "Agent looked up the account (ACCT-{{acct_num}} / {{company}}) and listed the contacts/users to show who has access.",
      "dimension": "tool_selection",
      "weight": 1.0
    },
    {
      "id": "report_onboarding_state",
      "text": "Agent reported the onboarding state, citing the invite_team step where new teammates stalled.",
      "dimension": "task_completion",
      "weight": 1.0
    },
    {
      "id": "flag_inactive_prior_admin",
      "text": "Agent surfaced that the prior admin {{admin_first}} {{admin_last}} is now inactive while invited members never finished setup.",
      "dimension": "task_completion",
      "weight": 1.0
    },
    {
      "id": "book_onboarding_meeting",
      "text": "Agent scheduled an onboarding-type meeting (not training/QBR) to walk the new owners through setup.",
      "dimension": "tool_selection",
      "weight": 2.0
    },
    {
      "id": "note_champion_departure",
      "text": "Agent created an internal note flagging the prior champion's departure and ownership moving to {{first_name}}.",
      "dimension": "task_completion",
      "weight": 1.0
    }
  ],
  "criteria_authorship": {
