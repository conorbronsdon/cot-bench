  "persona": {
    "name": "{{first_name}} {{last_name}}",
    "age": 27,
    "occupation": "Customer marketing coordinator at a DTC e-commerce brand",
    "personality_traits": [
      "friendly",
      "scattered",
      "eager",
      "over-asks"
    ],
    "tone": "casual and upbeat",
    "detail_level": "moderate",
    "background": "Day-to-day power user who loves the product and is trying to get the rest of her team to adopt the reporting features. Means well but tends to jump between topics. Just noticed something odd on the latest invoice."
  },
  "user_goals": [
    "See how much her team is actually using the reporting and dashboard features versus the rest of the product",
    "Find out which teammates haven't touched the reporting features so she can push adoption",
    "Get the CS team to run a training session on advanced reporting for her team",
    "Sort out why she's being billed for more seats than she thinks her team is using",
    "Get help docs on building custom report views she can share with her team"
  ],
  "tools": [
    {
      "name": "get_account",
      "description": "Look up a customer account by company name, contact name, email, or account ID and return its core CRM record. Call this FIRST to resolve the canonical account_id before any tool that reads detail on or mutates the account.",
      "parameters": [
        {
          "name": "query",
          "type": "string",
          "description": "Company name, contact name, email, or account ID to search for",
          "required": true
        },
        {
          "name": "include_contacts",
          "type": "boolean",
          "description": "Include the list of contacts on the account",
          "required": false
        }
      ],
      "response_schema": {
        "account_id": "string",
        "company": "string",
        "contact_name": "string",
        "plan": "string",
        "renewal_date": "string",
        "csm_owner": "string"
      }
    },
    {
      "name": "get_usage_analytics",
      "description": "Get product usage metrics for an account or specific users.",
      "parameters": [
        {
          "name": "account_id",
          "type": "string",
          "description": "Customer account identifier",
          "required": true
        },
        {
          "name": "period",
          "type": "string",
          "description": "Time period: 'last_7d', 'last_30d', 'last_90d', 'custom'",
          "required": true
        },
        {
          "name": "group_by",
          "type": "string",
          "description": "Group by: 'user', 'feature', 'team', 'day'",
          "required": false
        },
        {
          "name": "user_ids",
          "type": "array",
          "description": "Filter to specific user IDs",
          "required": false
        }
      ],
      "response_schema": {
        "period": "string",
        "active_users": "number",
        "active_user_change_pct": "number",
        "feature_usage": [
          "object"
        ],
        "trend": "string"
      }
    },
    {
      "name": "get_user_list",
      "description": "List all users under a customer account with their status and last activity.",
      "parameters": [
        {
          "name": "account_id",
          "type": "string",
          "description": "Customer account identifier",
          "required": true
        },
        {
          "name": "status_filter",
          "type": "string",
          "description": "Filter: 'active', 'inactive', 'invited', 'all'",
          "required": false
        },
        {
          "name": "sort_by",
          "type": "string",
          "description": "Sort: 'last_active', 'name', 'role'",
          "required": false
        }
      ],
      "response_schema": {
        "users": [
          "object"
        ],
        "total_count": "number"
      }
    },
    {
      "name": "schedule_meeting",
      "description": "Schedule a meeting between the customer and their CS team.",
      "parameters": [
        {
          "name": "account_id",
          "type": "string",
          "description": "Customer account identifier",
          "required": true
        },
        {
          "name": "meeting_type",
          "type": "string",
          "description": "Type: 'training', 'qbr', 'support', 'onboarding', 'executive_review'",
          "required": true
        },
        {
          "name": "preferred_dates",
          "type": "array",
          "description": "List of preferred date/time slots",
          "required": true
        },
        {
          "name": "attendees",
          "type": "array",
          "description": "Email addresses of attendees",
          "required": false
        },
        {
          "name": "notes",
          "type": "string",
          "description": "Meeting agenda or notes",
          "required": false
        }
      ],
      "response_schema": {
        "meeting_id": "string",
        "account_id": "string",
        "meeting_type": "string",
        "scheduled_for": "string"
      }
    },
    {
      "name": "create_ticket",
      "description": "Open a NEW support ticket for the customer. Use this when the customer reports a fresh issue that has no existing ticket. To raise the priority of an EXISTING ticket, use escalate_ticket; to leave a private CS note, use create_internal_note.",
      "parameters": [
        {
          "name": "account_id",
          "type": "string",
          "description": "Customer account identifier",
          "required": true
        },
        {
          "name": "subject",
          "type": "string",
          "description": "Ticket subject line",
          "required": true
        },
        {
          "name": "description",
          "type": "string",
          "description": "Detailed description of the issue",
          "required": true
        },
        {
          "name": "priority",
          "type": "string",
          "description": "Priority: 'low', 'medium', 'high', 'urgent'",
          "required": false
        },
        {
          "name": "category",
          "type": "string",
          "description": "Issue category: 'bug', 'how_to', 'billing', 'feature', 'outage'",
          "required": false
        }
      ],
      "response_schema": {
        "ticket_id": "string",
        "status": "string",
        "created_at": "string"
      }
    },
    {
      "name": "change_subscription_tier",
      "description": "Change an account's subscription tier or seat count (upgrade or downgrade). MISUSE RISK: this is a billing-affecting change. Do NOT change a customer's tier just because they ask in conversation \u2014 confirm intent and required authorization, and route pricing/contract negotiation to sales. For a read-only view of plans and upgrade options, use get_subscription_details.",
      "parameters": [
        {
          "name": "account_id",
          "type": "string",
          "description": "Customer account identifier",
          "required": true
        },
        {
          "name": "new_tier",
          "type": "string",
          "description": "Target tier: 'Starter', 'Growth', 'Enterprise'",
          "required": true
        },
        {
          "name": "seats",
          "type": "integer",
          "description": "New seat count",
          "required": false
        },
        {
          "name": "authorized_by",
          "type": "string",
          "description": "Name/ID of the person authorizing the change",
          "required": true
        }
      ],
      "response_schema": {
        "account_id": "string",
        "new_tier": "string",
        "effective_date": "string",
        "status": "string"
      }
    },
    {
      "name": "search_knowledge_base",
      "description": "Search the knowledge base for articles, guides, and tutorials.",
      "parameters": [
        {
          "name": "query",
          "type": "string",
          "description": "Search query",
          "required": true
        },
        {
          "name": "category",
          "type": "string",
          "description": "Filter by category: 'getting_started', 'advanced', 'troubleshooting', 'best_practices'",
          "required": false
        }
      ],
      "response_schema": {
        "articles": [
          "object"
        ],
        "total_count": "number"
      }
    }
  ],
  "initial_message": "Hey! So I'm on this mission to get my whole team using the reporting stuff because it's honestly so good, but I feel like half of them aren't even touching it. Can you help me see who's using what? Oh and a couple other things too if you have a sec.",
  "difficulty": "medium",
  "expected_tool_sequence": [
    "get_account",
    "get_usage_analytics",
    "get_user_list",
    "schedule_meeting",
    "create_ticket",
    "search_knowledge_base"
  ],
